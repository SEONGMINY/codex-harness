{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "files_to_read_next"],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "questions_needed",
        "docs_approval_needed",
        "planned",
        "generated",
        "blocked"
      ]
    },
    "task_path": {
      "type": ["string", "null"]
    },
    "files_to_read_next": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
